# ==========================================
# Base de données
# ==========================================
# DATABASE_URL : utilisée par l'application (Next.js) — mets l'URL "pooled" de Neon (celle avec -pooler)
DATABASE_URL="postgresql://user:password@localhost:5432/freelancemarket"
# DIRECT_URL : utilisée uniquement pour les migrations Prisma — mets l'URL directe de Neon (sans -pooler)
DIRECT_URL="postgresql://user:password@localhost:5432/freelancemarket"

# ==========================================
# Authentification
# ==========================================
JWT_SECRET="change-moi-en-production"
NEXTAUTH_SECRET="change-moi-en-production"
NEXTAUTH_URL="http://localhost:3000"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ==========================================
# Stockage (Cloudinary)
# ==========================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ==========================================
# Paiement (Stripe)
# ==========================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=""

# ==========================================
# Emails (Resend)
# ==========================================
RESEND_API_KEY=""
EMAIL_FROM="contact@freelancemarket.com"

# ==========================================
# Divers
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kori"
